# ─────────────────────────────────────────────────────────────────
#  BiltyVault — Local Development Environment
#
#  Copy this file to .env and fill in real values for local dev.
#  NEVER commit .env to version control.
#
#  On Railway, all variables below are set via the Railway dashboard
#  or are injected automatically (e.g. DATABASE_URL from the
#  linked Postgres service). The .env file is NOT loaded in
#  production (NODE_ENV=production).
# ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway injects this automatically
# when a Postgres service is linked; set manually for local dev)
DATABASE_URL=postgresql://user:password@localhost:5432/biltyvault

# A strong random string used to sign session cookies
SESSION_SECRET=replace-with-a-long-random-secret

# The password users enter to log in to the app
APP_PASSWORD=replace-with-your-app-password

# Google Gemini API key (optional — AI extract is disabled without it)
GEMINI_API_KEY=

# Set to "development" locally; Railway sets this to "production"
NODE_ENV=development

# Port the server listens on (Railway sets this automatically)
PORT=3000
